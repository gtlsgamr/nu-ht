---
import { Image } from 'astro:assets';
import Base from "../layouts/Base.astro";

// All artwork is loaded automatically from src/assets/artwork/*.webp
const modules = import.meta.glob('../assets/artwork/*.webp', { eager: true });
const art = {};
for (const path in modules) {
  const name = path.split('/').pop().replace(/\.webp$/, '');
  art[name] = modules[path].default;
}

// TO ADD / REMOVE / REORDER ARTWORK:
//   1. drop the .webp into src/assets/artwork/
//   2. add (or move) its filename — without ".webp" — in this list.
// Anything not listed here simply won't be shown.
const order = [
  "HTvsTheworld", "808s_PIXEL3", "skul", "nostalgia", "dogincar", "himesh",
  "Music", "ARTist", "Horseface", "Surya1", "skull2", "mask", "makepeace",
  "srk", "3p01", "Starry_girl", "angelsndemons", "PIXEL_1", "404_2_col",
  "Existloudly", "skull", "Corona", "jesse", "SMD", "Surya2", "mandomobile",
  "Soul_on_fire", "monsterhands", "fightthepower", "sentience", "Ghostinbulb",
  "littleaccident", "PicsArt_07_21_10", "ARTPROJEcT", "dosti", "azadi",
  "NEWSPAPER", "Sky_rainbow", "charlie", "Riverofdarknes",
  "00100sPORTRAIT_00100_BURST20190214181655816_COVER1", "baldisbold", "amb",
  "3p02", "TungstenBulbsSmokingBongs", "duba", "amittr", "shitpost", "nightm_3",
  "climate_change_small", "FALL", "Rockmonster", "stoneocean", "tea",
  "dontletmefall", "404", "shaktimaan", "Untitled_1_2", "hittarthsamurai",
  "abeysaale", "butterfliesinstomach", "crucifyme", "KEANU", "nohelp", "404_2",
  "Diwana", "I_AM_A_GOD", "outrun", "nightm_1", "detrasdh", "modi", "escape",
  "chai", "makani", "Caveman", "spacetrip", "firebreathingmonk", "mando",
];

const artworks = order.filter((name) => art[name]);
---
<Base title="Artworks" description="Digital artwork by Hitarth Thummar — vaporwave themes and pop-culture remixes made in Photoshop." image="/og/pages/artwork.png">
  <div class="max-w-7xl mx-auto">
    <!-- Page Header -->
    <header class="mb-brutalist-xl">
      <h1 class="text-brutalist-4xl md:text-brutalist-5xl font-display font-medium leading-tight text-brutalist-text">
        Artwork
      </h1>
    </header>

    <!-- Introduction -->
    <section class="mb-brutalist-2xl max-w-3xl">
      <div class="space-y-brutalist-sm text-brutalist-base md:text-brutalist-lg leading-relaxed text-brutalist-text/90">
        <p class="font-display text-brutalist-lg md:text-brutalist-xl text-brutalist-text">
          This is my artwork. Wait patiently for images to load.
        </p>
        <p>
          Back in college, I learned Photoshop out of curiosity and proceeded to make
          some artwork that I think is pretty good. The themes include photographs taken
          by me during my stay in Ahmedabad and pop culture icons that were influential
          in my upbringing. I relied heavily on vaporwave themes for most of the artwork.
          Many of these pictures are also entirely made from scratch by me.
        </p>
      </div>
    </section>

    <!-- Gallery -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-brutalist-md mb-brutalist-2xl">
      {artworks.map((name) => (
        <div class="overflow-hidden border-brutalist border-brutalist-text transition-colors duration-200 ease-out hover:border-brutalist-orange">
          <Image src={art[name]} alt={name} quality="low" class="w-full h-full object-cover" />
        </div>
      ))}
    </div>

    <!-- License -->
    <section class="border-t border-brutalist-border/40 pt-brutalist-lg">
      <div class="max-w-3xl">
        <h2 class="text-brutalist-xl md:text-brutalist-2xl font-display text-brutalist-text mb-brutalist-sm">
          License
        </h2>
        <div class="font-mono text-brutalist-sm space-y-brutalist-xs text-brutalist-border">
          <p>Artworks © by Hitarth Thummar</p>
          <p>
            The above artworks are licensed under a
            <a href="http://creativecommons.org/licenses/by-sa/4.0/" class="text-brutalist-orange underline underline-offset-4 decoration-brutalist-orange/40 hover:decoration-brutalist-orange transition-colors duration-200 ease-out">
              Creative Commons Attribution-ShareAlike 4.0 International License
            </a>.
          </p>
        </div>
      </div>
    </section>
  </div>
</Base>
