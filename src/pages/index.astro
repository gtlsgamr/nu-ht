---
import Base from "../layouts/Base.astro";
import data from "../../data.js";
import { getCollection } from "astro:content";

const poemPosts = await getCollection("poems");
const blogPosts = await getCollection("posts");
const allPosts = [...poemPosts, ...blogPosts];

const recentPosts = allPosts
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 5);
---

<Base title="home" description="Personal website of Hitarth Thummar — a developer and poet from Gujarat, India. Code, poems, artwork, and reflections." image="/og/pages/home.png">
  <!-- Intro -->
  <section>
    <h2 class="text-brutalist-2xl md:text-brutalist-3xl font-display text-brutalist-text mb-brutalist-sm">
      I'm <span class="text-brutalist-orange">Hitarth</span>,
    </h2>
    <div class="space-y-3 text-brutalist-base md:text-brutalist-lg leading-relaxed text-brutalist-text">
      <p>A guy from Gujarat, India. Welcome to my personal webspace.</p>
      <p>
        This is a place where I share everything I find interesting, amusing,
        or worth keeping: code, poems, and reflections on things that matter
        to me.
      </p>
    </div>
  </section>

  <!-- Contact -->
  <section class="mt-brutalist-xl">
    <h3 class="text-brutalist-xl font-display text-brutalist-text mb-brutalist-sm">Contact</h3>
    <ul class="list-[square] pl-5 space-y-1 text-brutalist-base text-brutalist-text">
      <li>
        Email:
        <a href={`mailto:${data.email}`} class="text-brutalist-orange underline underline-offset-2 hover:text-brutalist-text transition-colors duration-200 ease-out break-all">
          {data.email}
        </a>
      </li>
      <li>
        {data.social.map((s, i) => (
          <>
            {i > 0 && <span class="text-brutalist-border">, </span>}
            <a href={s.href} class="text-brutalist-orange underline underline-offset-2 hover:text-brutalist-text transition-colors duration-200 ease-out">{s.label}</a>
          </>
        ))}
      </li>
    </ul>
  </section>

  <!-- Quote box -->
  <section class="mt-brutalist-xl">
    <blockquote class="border-brutalist border-brutalist-text bg-brutalist-text/[0.06] px-brutalist-md py-brutalist-md">
      <p class="text-brutalist-lg md:text-brutalist-xl font-display italic leading-snug text-brutalist-text">
        The butterfly counts not months but moments, and has time enough.
      </p>
    </blockquote>
  </section>

  <!-- Recent Posts -->
  <section class="mt-brutalist-xl pt-brutalist-md border-t-brutalist border-brutalist-text">
    <h3 class="text-brutalist-xl font-display text-brutalist-text mb-brutalist-xs">Recent Posts</h3>
    <ul class="list-none p-0 m-0">
      {recentPosts.map((post) => (
        <li class="py-3 border-b border-brutalist-text last:border-b-0">
          <a href={`/${post.collection}/${post.slug}`} class="group block no-underline">
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-0.5 md:gap-4">
              <span class="text-brutalist-base md:text-brutalist-lg font-display text-brutalist-text group-hover:text-brutalist-orange group-hover:underline underline-offset-4 transition-colors duration-200 ease-out">
                {post.data.title}
              </span>
              <span class="font-mono text-brutalist-xs text-brutalist-border whitespace-nowrap tracking-wide">
                {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            </div>
            {post.data.description?.trim() && (
              <p class="text-brutalist-sm text-brutalist-text/75 leading-snug mt-1 max-w-2xl">
                {post.data.description}
              </p>
            )}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
