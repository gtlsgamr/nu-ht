---
import { getCollection } from 'astro:content';
import BaseBlogPost from '../../layouts/BaseBlogPost.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('posts');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const ogImage = entry.data.image ?? `/og/posts/${entry.slug}.png`;
---
<BaseBlogPost frontmatter={entry.data} title={entry.data.title} description={entry.data.description} date={entry.data.date} image={ogImage}>
    {entry.data.tags && entry.data.tags.length > 0 && (
      <div class="not-prose flex flex-wrap gap-x-3 gap-y-1 mb-brutalist-xl font-mono text-brutalist-xs">
        {entry.data.tags.map((tag) => (
          <a href={`/tags/${tag}`} class="text-brutalist-border hover:text-brutalist-orange transition-colors duration-200 ease-out no-underline">
            #{tag}
          </a>
        ))}
      </div>
    )}
    <Content />
</BaseBlogPost>
