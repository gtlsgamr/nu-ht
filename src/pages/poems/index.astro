---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import BlogPreview from "../../components/BlogPreview.astro";

const pageTitle = "Poems";
const allPosts = await getCollection("poems");

const sortedPosts = allPosts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Group by year
const postsByYear = sortedPosts.reduce((acc, post) => {
  const year = new Date(post.data.date).getFullYear();
  acc[year] = acc[year] || [];
  acc[year].push(post);
  return acc;
}, {});
---

<Base title={pageTitle} description="A collection of poems by Hitarth Thummar, in English and Hindi." image="/og/pages/poems.png">
  <div class="max-w-3xl mx-auto">
    <!-- Page Header -->
    <header class="mb-brutalist-2xl">
      <h1 class="text-brutalist-4xl md:text-brutalist-5xl font-display font-medium leading-tight text-brutalist-text">
        Poetry
      </h1>
      <p class="font-mono text-brutalist-xs text-brutalist-border tracking-wide mt-2">
        {sortedPosts.length} poems
      </p>
    </header>

    <!-- Poems by Year -->
    <div class="space-y-brutalist-2xl">
      {
        Object.entries(postsByYear)
            .sort((a, b) => b[0] - a[0])
            .map(([year, posts]) => (
            <section>
              <div class="mb-brutalist-md flex items-center gap-4">
                <h2 class="text-brutalist-xl font-display text-brutalist-border">
                  {year}
                </h2>
                <span class="flex-1 h-px bg-brutalist-border/30"></span>
              </div>
              <div>
                {
                  posts.map(post => (
                      <BlogPreview
                          title={post.data.title}
                          date={post.data.date}
                          body={post.body}
                          slug={post.slug}
                          type="poems"
                          tags={post.data.tags}
                          description={post.data.description}
                      />
                  ))
                }
              </div>
            </section>
        ))
      }
    </div>
  </div>
</Base>
