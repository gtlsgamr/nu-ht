---
import data from "../../data.js";
import NavBird from "./NavBird.astro";

const currentPath = Astro.url.pathname;

const links = [
  { href: "/posts", label: "blog", match: (p) => p.startsWith("/posts") },
  { href: "/poems", label: "poems", match: (p) => p.startsWith("/poems") },
  { href: "/artwork", label: "artwork", match: (p) => p === "/artwork" },
  { href: "/mahabharat", label: "mahabharat", match: (p) => p.startsWith("/mahabharat") },
  { href: "/about", label: "about", match: (p) => p === "/about" },
];
---

<header class="pt-brutalist-lg md:pt-brutalist-xl pb-brutalist-md">
  <!-- Masthead -->
  <a href="/" class="group block no-underline">
    <h1 class="text-brutalist-3xl md:text-brutalist-5xl font-display font-medium leading-none tracking-tight text-brutalist-text group-hover:text-brutalist-orange transition-colors duration-200 ease-out">
      <span class="hidden md:inline">{data.siteTitle}</span>
      <span class="md:hidden">{data.siteMobileTitle}</span>
    </h1>
    <p class="font-mono text-brutalist-xs text-brutalist-border mt-2 tracking-wide">
      {data.subTitle}
    </p>
  </a>

  <!-- Navigation: a thin ink rule (the bird perches on it). Not sticky. -->
  <nav class="relative border-t-brutalist border-brutalist-text mt-brutalist-md">
    <NavBird />
    <div class="flex items-center justify-between pt-brutalist-sm">
      <ul class="flex flex-wrap gap-x-4 gap-y-1 md:gap-x-6 list-none m-0 p-0">
        {links.map((link) => {
          const active = link.match(currentPath);
          return (
            <li>
              <a
                href={link.href}
                class={`font-display text-brutalist-lg md:text-brutalist-xl tracking-tight transition-colors duration-200 ease-out ${active ? 'text-brutalist-orange underline underline-offset-4 decoration-2' : 'text-brutalist-text hover:text-brutalist-orange'}`}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
      <a
        href="/atom.xml"
        class="p-1 text-brutalist-text hover:text-brutalist-orange transition-colors duration-200 ease-out"
        aria-label="RSS Feed"
      >
        <svg class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36zM4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
      </a>
    </div>
  </nav>
</header>
