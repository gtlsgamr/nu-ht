---
const {title, date, slug, type, tags = [], description = ''} = Astro.props;
const options = {
    year: 'numeric', month: 'long', day: 'numeric'
};
const formattedDate = new Date(date).toLocaleString('en-US',options);
const excerpt = (description ?? '').trim();
---
<article class="group py-brutalist-sm border-b border-brutalist-text">
  <a href={slug} class="block no-underline">
    <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 md:gap-4">
      <h2 class="text-brutalist-lg md:text-brutalist-xl font-display text-brutalist-text group-hover:text-brutalist-orange group-hover:underline underline-offset-4 transition-colors duration-200 ease-out">
        {title}
      </h2>
      <time class="font-mono text-brutalist-xs text-brutalist-border whitespace-nowrap tracking-wide">
        {formattedDate}
      </time>
    </div>

    {excerpt && (
      <p class="text-brutalist-base text-brutalist-text/80 leading-snug mt-1 max-w-2xl">
        {excerpt}
      </p>
    )}
  </a>
</article>
