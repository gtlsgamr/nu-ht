---
import Base from "./Base.astro";
import data from "../../data.js";
const {title, description, date, image} = Astro.props;

const options = {
    year: 'numeric', month: 'long', day: 'numeric'
};
const formattedDate = date ? new Date(date).toLocaleString('en-US', options) : '';
---
<Base title={title} description={description} image={image} article={true} date={date}>
    <article class="max-w-3xl mx-auto">
        <!-- Title Section -->
        <header class="mb-brutalist-xl pb-brutalist-lg border-b border-brutalist-border">
            <h1 class="text-brutalist-3xl md:text-brutalist-4xl font-display font-medium leading-tight mb-brutalist-sm text-brutalist-text">
                {title}
            </h1>
            {formattedDate && (
                <div class="font-mono text-brutalist-sm text-brutalist-border tracking-wide">
                    {formattedDate}
                </div>
            )}
        </header>

        <!-- Content -->
        <div class="prose prose-lg max-w-none mb-brutalist-2xl">
            <slot/>
        </div>

        <!-- Reply Section -->
        <footer class="border-t border-brutalist-border/40 pt-brutalist-lg mt-brutalist-2xl">
            <div class="font-mono text-brutalist-sm">
                <span class="text-brutalist-border">Reply via email</span>
                <a
                    href={`mailto:${data.email}?subject=Re:%20${title}`}
                    class="ml-2 text-brutalist-orange underline underline-offset-4 decoration-brutalist-orange/40 hover:decoration-brutalist-orange transition-colors duration-200 ease-out"
                >
                    say hello →
                </a>
            </div>
        </footer>
    </article>
</Base>
